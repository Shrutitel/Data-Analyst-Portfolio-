      <aliases enabled='yes' />
      <column caption='Sales 2021' datatype='real' name='[Calculation_0411554960179204]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF  YEAR([Order_Date]) = 2021 THEN [Sales] END' />
      </column>
      <column caption='Sales 2022' datatype='real' name='[Calculation_0411554960388101]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF  YEAR([Order_Date]) = 2022 THEN [Sales] END' />
      </column>
      <column caption='KPI colors ' datatype='string' name='[Calculation_0674064222588930]' role='measure' type='nominal'>
        <calculation class='tableau' formula='If SUM([Sales]) &gt; 700000 THEN &quot;Green&quot;&#13;&#10;ELSEIF SUM([Sales]) &lt; 700000 OR SUM([Sales]) &gt; 600000 THEN &quot;Orange&quot;&#13;&#10;ELSE &quot;Red&quot;&#13;&#10;END' />
      </column>
      <column caption='KPI ' datatype='string' name='[Calculation_1232888724475904]' role='measure' type='nominal'>
        <calculation class='tableau' formula='If sum([Sales]) &gt; [Parameters].[Quantity Parameter] then &apos;Green&apos; &#13;&#10;ELSE &apos;Red&apos;&#13;&#10;end' />
      </column>
      <column caption='Dynamic caluculations' datatype='string' name='[Calculation_1232888732295170]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='Case [Parameters].[Parameter 2]&#13;&#10;WHEN &apos;Country&apos; THEN [Country]&#13;&#10;WHEN &apos;Category&apos; THEN [Category]&#13;&#10;END' />
